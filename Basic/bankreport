#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#define MAX_ACCOUNTS 200
#define FILE_NAME "bank.dat"


struct Account {
    int accNo;
    char name[50];
    char phone[15];
    char address[100];
    float balance;
};


struct Account bank[MAX_ACCOUNTS];
int total = 0;

void loadData();
void saveData();

void createAccount();
void displayAccounts();
void searchAccount();
void depositMoney();
void withdrawMoney();
void transferMoney();
void updateAccount();
void deleteAccount();
void sortAccounts();

void pressEnter();


int main() {
    int choice;

    loadData();

    while (1) {
        printf("\n=================================================\n");
        printf("               BANK MANAGEMENT SYSTEM             \n");
        printf("=================================================\n");
        printf("1. Create New Account\n");
        printf("2. Display All Accounts\n");
        printf("3. Search Account\n");
        printf("4. Deposit Money\n");
        printf("5. Withdraw Money\n");
        printf("6. Transfer Money\n");
        printf("7. Update Account Details\n");
        printf("8. Delete Account\n");
        printf("9. Sort Accounts by Balance\n");
        printf("10. Save & Exit\n");
        printf("-------------------------------------------------\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: createAccount(); break;
            case 2: displayAccounts(); break;
            case 3: searchAccount(); break;
            case 4: depositMoney(); break;
            case 5: withdrawMoney(); break;
            case 6: transferMoney(); break;
            case 7: updateAccount(); break;
            case 8: deleteAccount(); break;
            case 9: sortAccounts(); break;
            case 10:
                saveData();
                printf("\nData saved successfully.\n");
                printf("Thank you for using the Bank System.\n");
                exit(0);
            default:
                printf("\nInvalid choice! Try again.\n");
        }
    }
}


void loadData() {
    FILE *fp = fopen(FILE_NAME, "rb");
    if (fp == NULL) {
        total = 0;
        return;
    }
    fread(&total, sizeof(int), 1, fp);
    fread(bank, sizeof(struct Account), total, fp);
    fclose(fp);
}


void saveData() {
    FILE *fp = fopen(FILE_NAME, "wb");
    if (fp == NULL) {
        printf("Error saving data!\n");
        return;
    }
    fwrite(&total, sizeof(int), 1, fp);
    fwrite(bank, sizeof(struct Account), total, fp);
    fclose(fp);
}

/* ----------------------------- CREATE ACCOUNT ----------------------------- */
void createAccount() {
    if (total >= MAX_ACCOUNTS) {
        printf("\nBank storage full!\n");
        return;
    }

    printf("\nEnter Account Number: ");
    scanf("%d", &bank[total].accNo);

    printf("Enter Name: ");
    getchar();
    fgets(bank[total].name, 50, stdin);
    bank[total].name[strcspn(bank[total].name, "\n")] = 0;

    printf("Enter Phone Number: ");
    fgets(bank[total].phone, 15, stdin);
    bank[total].phone[strcspn(bank[total].phone, "\n")] = 0;

    printf("Enter Address: ");
    fgets(bank[total].address, 100, stdin);
    bank[total].address[strcspn(bank[total].address, "\n")] = 0;

    printf("Enter Initial Balance: ");
    scanf("%f", &bank[total].balance);

    total++;

    printf("\nAccount created successfully!\n");
    pressEnter();
}

/* ----------------------------- DISPLAY ACCOUNTS ----------------------------- */
void displayAccounts() {
    if (total == 0) {
        printf("\nNo accounts available.\n");
        pressEnter();
        return;
    }

    printf("\n--------------------------------------------------------------------------------\n");
    printf("AccNo\tName\t\tPhone\t\tBalance\n");
    printf("--------------------------------------------------------------------------------\n");

    for (int i = 0; i < total; i++) {
        printf("%d\t%-15s\t%-12s\t%.2f\n",
               bank[i].accNo,
               bank[i].name,
               bank[i].phone,
               bank[i].balance);
    }

    pressEnter();
}

/* ----------------------------- SEARCH ACCOUNT ----------------------------- */
void searchAccount() {
    int acc, found = 0;
    printf("\nEnter account number to search: ");
    scanf("%d", &acc);

    for (int i = 0; i < total; i++) {
        if (bank[i].accNo == acc) {
            printf("\nAccount Found!\n");
            printf("Name    : %s\n", bank[i].name);
            printf("Phone   : %s\n", bank[i].phone);
            printf("Address : %s\n", bank[i].address);
            printf("Balance : %.2f\n", bank[i].balance);
            found = 1;
            break;
        }
    }

    if (!found)
        printf("\nAccount not found!\n");

    pressEnter();
}

/* ----------------------------- DEPOSIT MONEY ----------------------------- */
void depositMoney() {
    int acc;
    float amt;

    printf("\nEnter account number: ");
    scanf("%d", &acc);

    for (int i = 0; i < total; i++) {
        if (bank[i].accNo == acc) {
            printf("Enter deposit amount: ");
            scanf("%f", &amt);
            bank[i].balance += amt;
            printf("\nAmount deposited successfully!\n");
            pressEnter();
            return;
        }
    }

    printf("\nAccount not found!\n");
    pressEnter();
}

/* ----------------------------- WITHDRAW MONEY ----------------------------- */
void withdrawMoney() {
    int acc;
    float amt;

    printf("\nEnter account number: ");
    scanf("%d", &acc);

    for (int i = 0; i < total; i++) {
        if (bank[i].accNo == acc) {
            printf("Enter withdrawal amount: ");
            scanf("%f", &amt);

            if (amt > bank[i].balance) {
                printf("\nInsufficient balance!\n");
            } else {
                bank[i].balance -= amt;
                printf("\nPlease collect your cash.\n");
            }
            pressEnter();
            return;
        }
    }

    printf("\nAccount not found!\n");
    pressEnter();
}

/* ----------------------------- TRANSFER MONEY ----------------------------- */
void transferMoney() {
    int from, to;
    float amt;

    printf("\nEnter sender account number: ");
    scanf("%d", &from);

    printf("Enter receiver account number: ");
    scanf("%d", &to);

    printf("Enter amount: ");
    scanf("%f", &amt);

    int f = -1, t = -1;

    for (int i = 0; i < total; i++) {
        if (bank[i].accNo == from) f = i;
        if (bank[i].accNo == to) t = i;
    }

    if (f == -1 || t == -1) {
        printf("\nInvalid account number!\n");
    } else if (bank[f].balance < amt) {
        printf("\nInsufficient balance!\n");
    } else {
        bank[f].balance -= amt;
        bank[t].balance += amt;
        printf("\nTransfer successful!\n");
    }

    pressEnter();
}

/* ----------------------------- UPDATE ACCOUNT ----------------------------- */
void updateAccount() {
    int acc;

    printf("\nEnter account number to update: ");
    scanf("%d", &acc);

    for (int i = 0; i < total; i++) {
        if (bank[i].accNo == acc) {
            getchar();

            printf("Enter new name: ");
            fgets(bank[i].name, 50, stdin);
            bank[i].name[strcspn(bank[i].name, "\n")] = 0;

            printf("Enter new phone: ");
            fgets(bank[i].phone, 15, stdin);
            bank[i].phone[strcspn(bank[i].phone, "\n")] = 0;

            printf("Enter new address: ");
            fgets(bank[i].address, 100, stdin);
            bank[i].address[strcspn(bank[i].address, "\n")] = 0;

            printf("\nAccount updated successfully!\n");
            pressEnter();
            return;
        }
    }

    printf("\nAccount not found!\n");
    pressEnter();
}

/* ----------------------------- DELETE ACCOUNT ----------------------------- */
void deleteAccount() {
    int acc;

    printf("\nEnter account number to delete: ");
    scanf("%d", &acc);

    for (int i = 0; i < total; i++) {
        if (bank[i].accNo == acc) {
            for (int j = i; j < total - 1; j++)
                bank[j] = bank[j + 1];
            total--;
            printf("\nAccount deleted successfully!\n");
            pressEnter();
            return;
        }
    }

    printf("\nAccount not found!\n");
    pressEnter();
}

/* ----------------------------- SORT ACCOUNTS ----------------------------- */
void sortAccounts() {
    struct Account temp;

    for (int i = 0; i < total - 1; i++) {
        for (int j = i + 1; j < total; j++) {
            if (bank[i].balance < bank[j].balance) {
                temp = bank[i];
                bank[i] = bank[j];
                bank[j] = temp;
            }
        }
    }

    printf("\nAccounts sorted by balance (descending).\n");
    pressEnter();
}

/* ----------------------------- PRESS ENTER ----------------------------- */
void pressEnter() {
    printf("\nPress Enter to continue...");
    getchar();
    getchar();
}
